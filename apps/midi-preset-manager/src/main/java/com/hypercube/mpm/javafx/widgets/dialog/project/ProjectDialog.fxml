<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<fx:root xmlns:fx="http://javafx.com/fxml/1" styleClass="mpmDialogShadow"
         stylesheets="@../../MainWindow.css,@../DialogCommon.css,@ProjectDialog.css" type="GridPane" xmlns="http://javafx.com/javafx/17.0.12"
         fx:controller="com.hypercube.mpm.javafx.widgets.dialog.project.ProjectDialogController">
    <!-- DEFINE PROPERTY String:errorMessage -->
    <GridPane styleClass="mpmDialog" vgap="10.0">
        <columnConstraints>
            <ColumnConstraints halignment="CENTER" minWidth="500.0"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="50.0"/>
            <RowConstraints/>
            <RowConstraints/>
            <RowConstraints/>
            <RowConstraints/>
            <RowConstraints/>
            <RowConstraints maxHeight="500.0" minHeight="50.0"/>
            <RowConstraints minHeight="40.0"/>
        </rowConstraints>
        <Label fx:id="textHeader" pickOnBounds="false" text="Project Editor" GridPane.rowIndex="0">
            <GridPane.margin>
                <Insets/>
            </GridPane.margin>
        </Label>
        <Label pickOnBounds="false" text="Devices states:" GridPane.halignment="LEFT" GridPane.rowIndex="1">
            <GridPane.margin>
                <Insets/>
            </GridPane.margin>
        </Label>
        <TableView fx:id="statesList" editable="true" GridPane.rowIndex="2" GridPane.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colLastUsed" minWidth="30.0" prefWidth="30.0"/>
                <TableColumn fx:id="colDevice" maxWidth="120.0" minWidth="120" text="Device"/>
                <TableColumn fx:id="colMode" prefWidth="128.0" text="Mode"/>
                <TableColumn fx:id="colChannel" maxWidth="64.0" minWidth="64.0" prefWidth="64.0" text="Ch"/>
                <TableColumn fx:id="colPatch" maxWidth="400.0" minWidth="400.0" prefWidth="400.0" text="Preset"/>
            </columns>
        </TableView>
        <HBox alignment="CENTER" spacing="20.0" GridPane.rowIndex="7">
            <Button minWidth="100.0" onAction="#onSaveButton" text="Save to disk">

            </Button>
            <Button minWidth="100.0" onAction="#onCancelButton" text="Cancel">

            </Button>
            <GridPane.margin>
                <Insets/>
            </GridPane.margin>
        </HBox>
        <padding>
            <Insets left="10.0" right="10.0"/>
        </padding>
    </GridPane>
    <columnConstraints>
        <ColumnConstraints/>
    </columnConstraints>
    <rowConstraints>
        <RowConstraints/>
    </rowConstraints>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>
</fx:root>
